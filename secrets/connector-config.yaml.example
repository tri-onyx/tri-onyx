gateway:
  url: ws://gateway:4000/connectors/ws
  connector_id: matrix-home
  token: "<your-secret-here>"
  instance_name: Tri-Onyx
adapters:
  matrix:
    enabled: true
    homeserver: https://matrix.org
    user_id: '@your-id:your-homeserver.org'
    access_token: "<your-secret-here>"
    device_id: TRI-ONYX-01
    store_path: /data/matrix
    trusted_users:
    - "@your-user:your-homeserver.org"
    rooms:
      "!example-room:your-homeserver.org":
        agent: main
        mode: mention
        merge_window_ms: 3000
        show_steps: true
        show_result: false
        step_mode: pretty
    heartbeat_rooms:
      your-agent: "!example-room:your-homeserver.org"
  slack:
    enabled: true
    bot_token: "<your-secret-here>"
    app_token: "<your-secret-here>"
    owner_user_id: "<your-secret-here>"
    default_agent: concierge
    consent_path: /data/slack/consent.yaml
